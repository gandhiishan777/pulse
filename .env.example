# Supabase project URL (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key — safe to expose to browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — SERVER ONLY, never expose to browser
# Used by the event ingestion API to bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret token for protecting the cron rollup endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret
